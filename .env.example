# Public site URL
NEXT_PUBLIC_SITE_URL=https://money.rxcloud.group

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional Ark CodingPlan config for generated lifecycle health-check tasks.
# Without this value, health checks fall back to deterministic template text.
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_CHAT_MODEL=doubao-seed-2-0-code-preview-260215

# Optional bearer secret for /api/cron/lifecycle-check.
# Production should set this in Vercel.
CRON_SECRET=your_cron_secret_here
